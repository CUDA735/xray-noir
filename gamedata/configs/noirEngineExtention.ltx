; =======================================================
; Noir Engine Global Extensions Configuration
; =======================================================

; Extended weather and environmental effects
[environment]
enable_rain_material_sounds = false ; Enables dynamic rain-on-material impact sounds (true = on / false = off)
enable_dynamic_rain_wind    = true ; Controls raindrop tilt and fall-speed response based on wind intensity defined in the weather system
enable_custom_lightning = true ;Renders lightning strikes around the player based on distance tiers and probability weights

[ui]
show_dialog_portraits = false ; true = show dialogue side panels, false = hide them